graph
    %% Definicja Stylów
    classDef main fill:#f9f,stroke:#333,stroke-width:2px;
    classDef sub fill:#bbf,stroke:#333,stroke-width:1px;
    classDef modal fill:#fdd,stroke:#333,stroke-width:2px,stroke-dasharray: 5 5;

    %% --- MODUŁ ROZGRYWKI ---
    subgraph Gameplay [Gameplay Domain]
        direction TB
        Main[MainPage]:::main
        Player[PlayerPage]:::sub
        Cmd[CommanderPage]:::sub
        PlayerSett[PlayerSettingsPage]:::sub
        ValEdit[ValueEditorPage]:::modal
        Kbd[KeyboardPage]:::modal
        
        Main --> Cmd
        Main --> ValEdit
        Main --> Player
        
        Player --> Main
        Player --> ValEdit
        Player --> PlayerSett
        
        PlayerSett --> Player
        PlayerSett --> Kbd
        
        Cmd --> Main
        Cmd --> ValEdit
        
        ValEdit -.-> Player
        ValEdit -.-> Cmd
        ValEdit -.-> Main
        
        Kbd -.-> PlayerSett
    end

    %% --- MODUŁ SYSTEMOWY ---
    subgraph System [System Domain]
        direction TB
        Menu[MenuPage]:::main
        Hist[ChangeHistoryPage]:::sub
        Dice[DicePage]:::sub
        Sett[SettingsPage]:::sub
        GameSett[GameSettingsPage]:::sub
        DevSett[DeviceSettingsPage]:::sub
        Names[ValueNamesPage]:::sub
        Conf[ConfirmPage]:::modal
        ResetAction((Game Reset)):::modal
        
        Menu --> Hist
        Menu --> Dice
        Menu --> Sett
        Menu --> Names
        Menu --> Conf
        
        Dice -.-> Menu
        Names -.-> Menu
        
        Sett --> GameSett
        Sett --> DevSett
        GameSett -.-> Sett
        DevSett -.-> Sett
        
        Conf --> ResetAction
        Conf --> Menu
    end

    %% --- POŁĄCZENIA MIĘDZYDOMENOWE ---
    Main --> Menu
    Menu -.-> Main
    Main --> Hist
    
    %% ValueNamesPage korzysta z generycznej klawiatury
    Names --> Kbd
    Kbd -.-> Names

    %% Reset gry przenosi użytkownika do ekranu głównego
    ResetAction ==> Main
